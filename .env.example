# Variables de entorno para Warren Indicator
# Copia este archivo a .env y reemplaza los valores

# Telegram Bot Configuration
# Obtén el token de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=tu_token_aqui

# Tu Chat ID (obténlo con @userinfobot)
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Intervalo de verificación en minutos (mínimo recomendado: 5)
CHECK_INTERVAL=5

# Símbolos a monitorear (separados por coma)
SYMBOLS=AAPL,GOOGL,TSLA,MSFT,NVDA
